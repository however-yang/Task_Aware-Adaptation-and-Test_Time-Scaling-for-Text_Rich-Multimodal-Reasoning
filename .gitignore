__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/

# 仅 Final/data/ 内数据与缓存不上传（其余如 logs、outputs 可正常提交）
data/raw/*
