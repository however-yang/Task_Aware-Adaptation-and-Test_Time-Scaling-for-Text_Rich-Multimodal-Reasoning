data/cache/*
!data/cache/.gitkeep
data/.cache/
data/processed/

outputs/checkpoints/*
!outputs/checkpoints/.gitkeep
outputs/predictions/*
!outputs/predictions/.gitkeep
outputs/metrics/*
!outputs/metrics/.gitkeep
outputs/analysis/*
!outputs/analysis/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep

*.tmp
